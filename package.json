{
  "name": "@novalux12/openclaw-umans-usage",
  "version": "0.1.2",
  "description": "OpenClaw provider plugin that surfaces Umans Code plan limits and usage in the Provider Plans & Billing dashboard",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "umans",
    "umans-ai",
    "provider"
  ],
  "author": "NovaLux12",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NovaLux12/openclaw-umans-usage.git"
  },
  "bugs": {
    "url": "https://github.com/NovaLux12/openclaw-umans-usage/issues"
  },
  "homepage": "https://github.com/NovaLux12/openclaw-umans-usage#readme",
  "peerDependencies": {
    "openclaw": ">=2026.7.1"
  },
  "devDependencies": {
    "openclaw": "2026.7.1",
    "typescript": "^5.5.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "providers": [
      "umans"
    ],
    "compat": {
      "pluginApi": ">=2026.7.1",
      "minGatewayVersion": "2026.7.1"
    },
    "build": {
      "openclawVersion": "2026.7.1",
      "pluginSdkVersion": "2026.7.1"
    }
  }
}
